# Podcast Index API (free, no rate cap)
PODCAST_INDEX_API_KEY=
PODCAST_INDEX_API_SECRET=

# Hunter.io API (free tier, 25 searches/mo)
HUNTER_API_KEY=

# Airtable (free tier, 1000 records/base)
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_PROSPECTS_TABLE_ID=

# OpenRouter (LLM calls for enrichment and call context)
OPENROUTER_API_KEY=

# Vapi Voice Agent (Phase 3)
# Get from: Vapi Dashboard > Organization > API Keys
VAPI_API_KEY=
# Get from: Vapi Dashboard > Phone Numbers > copy ID of free number
VAPI_PHONE_NUMBER_ID=
# ElevenLabs voice ID (default "JBFqnCBsd6RMkjVDRZzb" for George voice, can override)
VAPI_VOICE_ID=
# Defaults to localhost for demo. Set to ngrok URL when running tool server remotely.
TOOL_SERVER_URL=http://localhost:3000/tools
